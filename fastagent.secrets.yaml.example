# Copy this file to fastagent.secrets.yaml and fill in your Gemini API key.
# NEVER commit fastagent.secrets.yaml to git (it is gitignored).

google:
  api_key: "your-gemini-api-key-here"

# Ollama (student model: local, no key needed)
# Ollama must be running: `ollama serve`
# Pull a model first: `ollama pull llama3.2`
# Model name format:  generic.<model-name>  e.g. generic.llama3.2:latest

generic:
  base_url: "http://localhost:11434/v1"
  api_key: "ollama"
